    {
      "parameters": {
        "jsCode": "// ดึงข้อความทั้งหมดที่ AI ตอบกลับมา\nconst responseText = items[0].json.text;\n\n// ใช้ Regex ขั้นสูงเพื่อดึงเฉพาะเนื้อหาที่อยู่ในเครื่องหมาย { } ตัวแรกและตัวสุดท้าย\nconst jsonMatch = responseText.match(/\\{[\\s\\S]*\\}/);\n\nif (jsonMatch) {\n  try {\n    // แปลงข้อความที่ตัดมาได้ให้เป็น JSON Object\n    const rawData = JSON.parse(jsonMatch[0]);\n    \n    // ดึงเฉพาะ array ของหนังสือออกมา (ตามโครงสร้างที่คุณต้องการ)\n    const finalItems = rawData.selection_summary || [];\n    \n    // ส่งข้อมูลออกไปเป็นรายการ (Array of objects) เพื่อให้ Node ถัดไปใช้งานง่าย\n    return finalItems.map(item => ({ json: item }));\n    \n  } catch (e) {\n    // ถ้าพัง ให้ส่ง Error ออกไปดูว่ามันผิดที่บรรทัดไหน\n    throw new Error(\"JSON parse failed: \" + e.message + \". Content: \" + jsonMatch[0]);\n  }\n} else {\n  // กรณีหาเครื่องหมาย { } ไม่เจอเลย\n  return [{ json: { error: \"No JSON found\", raw_text: responseText } }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        16
      ],
      "id": "77682c2b-15cc-42a7-8b60-c04575af4c33",
      "name": "Code in JavaScript3",
      "retryOnFail": false,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Input: {{ JSON.stringify($items()) }}",
        "messages": {
          "messageValues": [
            {
              "message": "=You are a Procurement Specialist. Your task is to analyze a list of book quotations and select the best offer for each unique book. In your analysis, you must strictly identify unique items by combining the 'book_title' and its 'format' such as Physical Book or e-Book. If two items have the identical title but different formats, they must be treated as two distinct items and evaluated separately. For each unique item, select the vendor that offers the lowest 'net_price'. If the 'net_price' is tied between vendors for the exact same item and format, the tie-breaker is the 'estimated_delivery_day' where the shortest duration is preferred. The reason must be answered in Thai. Your response must be a valid raw JSON string starting with an open curly bracket and ending with a closing curly bracket, without any markdown formatting like triple backticks, conversational text, or explanations. The required JSON structure is { \"selection_summary\": [ { \"book_title\": \"string\", \"format\": \"Physical | e-Book\", \"selected_vendor\": \"string\", \"net_price\": number, \"currency\": \"string\", \"estimated_delivery_day\": \"string\", \"reason\": \"string\", \"quote_id\": \"number\", \"evaluation_id\": \"number\" } ], \"total_items_selected\": number }."
            }
          ]
        },
        "batching": {
          "batchSize": 1,
          "delayBetweenBatches": 3000
        }
      },

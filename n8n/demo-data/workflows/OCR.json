    {
      "parameters": {
        "jsCode": "// 1. ดึงข้อความทั้งหมดมา\nconst responseText = items[0].json.text;\n\n// 2. ใช้ Regex ที่หาจาก [ ไปจนถึง ] ตัวสุดท้ายของข้อความ\nconst jsonMatch = responseText.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n\nif (jsonMatch) {\n    try {\n        // ล้างช่องว่างที่อาจติดมา\n        const cleanRawData = jsonMatch[0].trim();\n        const cleanData = JSON.parse(cleanRawData);\n\n        // ส่งข้อมูลออกไปแบบแยกรายการ (Splitting items)\n        return cleanData.map(item => ({ json: item }));\n        \n    } catch (e) {\n        // ถ้ายังพัง ให้ลองส่ง error ออกมาดูว่ามันตัดข้อความมาได้แค่ไหน\n        throw new Error(\"JSON Parse Error: \" + e.message + \" | Data found: \" + jsonMatch[0].substring(0, 50) + \"...\");\n    }\n} else {\n    return [{ json: { items: [], message: \"No JSON array found in text\" } }];\n}"
      },

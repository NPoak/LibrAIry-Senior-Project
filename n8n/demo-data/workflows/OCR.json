      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pe.evaluation_id \nFROM policy_evaluations pe\nJOIN book_requests br ON pe.request_id = br.request_id\nWHERE \n    (br.isbn_issn = '{{ $json.isbn_issn }}')\n    OR \n    TRIM(LOWER(br.title)) LIKE TRIM(LOWER('%{{ $json.title }}%'))\nORDER BY \n    /* ให้ความสำคัญกับ ISBN Match ก่อน (ISBN Match = 0, Title Match = 1) */\n    (CASE WHEN br.isbn_issn = '{{ $json.isbn_issn }}' THEN 0 ELSE 1 END) ASC,\n    pe.evaluated_at DESC \nLIMIT 1;",
        "options": {}

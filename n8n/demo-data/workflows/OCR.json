    {
      "parameters": {
        "jsCode": "// 1. ดึงข้อมูลทั้งหมดที่ส่งเข้ามา (Input)\nconst allItems = $input.all(); \n\n// 2. รวมข้อความ content จากทุก item เข้าด้วยกัน\n// ใช้เครื่องหมาย ?. เพื่อป้องกัน error กรณีโครงสร้างข้อมูลบางตัวไม่สมบูรณ์\nconst combinedText = allItems.map(item => {\n  try {\n    return item.json.results[0].message.choices[0].message.content;\n  } catch (e) {\n    return \"\"; // ถ้าหา content ไม่เจอให้เป็นค่าว่าง\n  }\n}).filter(text => text !== \"\").join('\\n\\n--- Next Page ---\\n\\n');\n\n// 3. การดึง original_file_id ให้รองรับทั้ง 2 สาย (PDF และ JPG)\n// แนะนำให้ดึงจาก Node \"Loop Over Items2\" เพราะเป็นจุดร่วมที่ส่ง ID มาแน่นอนที่สุด\nlet fileId = \"\";\ntry {\n  // พยายามดึงจาก Loop Node ล่าสุด\n  fileId = $('Loop Over Items2').item.json.id;\n} catch (e) {\n  // ถ้าหาไม่เจอ ให้ดึงจาก Search files and folders เป็นแผนสำรอง\n  fileId = $('Search files and folders').item.json.id;\n}\n\n// 4. ส่งออกเป็น item เดียว\nreturn {\n  content: combinedText,\n  original_file_id: fileId\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1904,
        80
      ],
      "id": "9444ab5d-9013-448a-98c1-0dd0a039fcf3",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Input quotation:\n{{ $json.content }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a specialized Data Extraction API. Your ONLY task is to extract structured information from quotation OCR text and return a clean JSON Array of objects. CRITICAL LOGIC FOR MULTI-PAGE QUOTATIONS: IDENTIFY SUMMARY VS. DETAILS: Some quotations have a summary page listing a total count (e.g., \"6 items\") followed by detailed pages. SKIP SUMMARY LINE ITEMS: If a line item description mentions a collection of titles (e.g., \"จำนวน 6 ชื่อเรื่อง\"), DO NOT extract this as one item. You MUST find the itemized list where each book title, author, and ISBN are listed separately (usually in a table with columns like Title, Author, ISBN). VALIDATION: Every individual book found in the detailed list must be a separate object in the JSON array. STRICT OPERATIONAL RULES: NO CONVERSATION. NO CODE BLOCKS (No ```json). OUTPUT STRUCTURE: Always return a JSON Array []. DATA CLEANING: Remove commas from numeric values. Use only digits for ISBN. SCHEMA DEFINITION: title (string | null) is the book title extracted from the detailed list. authors (string | null) are the author name(s). isbn_issn (number | null) must be digits only. vendor_name (string | null) is the company name. contact_person (string | null) is the contact name. vendor_email (string | null) is the email address. telephone_number (string | null) is the contact number. book_format (string) must be \"EBOOK\" if text contains \"e-book\", \"ebook\", \"electronic\", or \"access\", otherwise \"PRINT\". unit_price (number | null) is the price for EACH individual book. quantity (number) defaults to 1. discount_type (string | null) is the type of discount applied. discount_value (number | null) is the numerical value of the discount. net_price (number | null) is the final mandatory price per item. currency (string) defaults to \"THB\". platform (string | null) is the e-book platform name. availability (string | null) is the stock or availability status. estimated_delivery_day (string | null) is the delivery timeframe(กำหนดส่งของ)."
            }
          ]
        },
        "batching": {}
      },

###############################################################################
# TIMEZONE CONFIGURATION (การตั้งค่าเขตเวลา)
###############################################################################
# เขตเวลาหลักของระบบและตู้คอนเทนเนอร์ (แนะนำ: Asia/Bangkok สำหรับประเทศไทย)
TZ=Asia/Bangkok
# เขตเวลาทั่วไปที่ n8n จะใช้ประมวลผลโหนด Schedule / Cron
GENERIC_TIMEZONE=Asia/Bangkok


###############################################################################
# POSTGRES DATABASE CONFIGURATION (การเชื่อมต่อฐานข้อมูล)
###############################################################################
# ชื่อผู้ใช้งานสิทธิ์ Admin ของระบบฐานข้อมูล PostgreSQL
POSTGRES_USER=your_postgres_username
# รหัสผ่านสำหรับเข้าใช้งาน PostgreSQL (ควรตั้งให้เดายากเพื่อความปลอดภัย)
POSTGRES_PASSWORD=your_secure_postgres_password
# ชื่อฐานข้อมูลหลัก ที่ระบบห้องสมุดและ n8n ใช้ร่วมกัน
POSTGRES_DB=your_database_name


###############################################################################
# N8N BASE CONFIGURATION (การตั้งค่าระบบหลักของ n8n)
###############################################################################
# โปรโตคอลในการเข้าถึง (http สำหรับทดสอบในเครื่อง / https สำหรับใช้งานจริงบน Production)
N8N_PROTOCOL=https

# Domain Name หลักที่ใช้เข้าหน้าเว็บ n8n (เช่น n8n.domain.com หรือโดเมนของ ngrok)
N8N_HOST=n8n.yourdomain.com

# URL เต็มรูปแบบสำหรับการรับส่งข้อมูล Webhook (ต้องลงท้ายด้วย / เสมอ)
WEBHOOK_URL=https://n8n.yourdomain.com/

# URL เต็มรูปแบบสำหรับเข้าหน้าแก้ไข Workflow (Editor) ของ n8n
N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com/

# เปิดใช้งานระบบยืนยันตัวตนขั้นพื้นฐาน (Basic Auth) ก่อนเข้าใช้งาน (true = เปิด / false = ปิด)
N8N_BASIC_AUTH_ACTIVE=true
# ชื่อผู้ใช้ในการล็อกอินเข้าหน้า n8n ผ่าน Basic Auth
N8N_BASIC_AUTH_USER=your_n8n_admin_username
# รหัสผ่านในการล็อกอินเข้าหน้า n8n ผ่าน Basic Auth
N8N_BASIC_AUTH_PASSWORD=your_n8n_admin_password

# รูปแบบการจัดเก็บข้อมูลประเภทไฟล์/ไบนารี (filesystem = ประหยัดแรมโดยเขียนลงฮาร์ดดิสก์คอนเทนเนอร์)
N8N_DEFAULT_BINARY_DATA_MODE=filesystem


###############################################################################
# N8N SECURITY SECRETS (รหัสเข้ารหัสความปลอดภัยของ n8n)
# *คำแนะนำ: สร้างสุ่มด้วยคำสั่ง `openssl rand -hex 32` ใน Terminal*
###############################################################################
# คีย์หลักที่ n8n ใช้เข้ารหัส Credentials (รหัสผ่าน/API Keys) ที่บันทึกไว้ในระบบ
N8N_ENCRYPTION_KEY=generate_strong_random_hex_32_chars
# คีย์ลับสำหรับระบบจัดการผู้ใช้เพื่อสร้างและตรวจสอบความถูกต้องของ JWT Token
N8N_USER_MANAGEMENT_JWT_SECRET=generate_another_strong_random_hex_32_chars


###############################################################################
# AI & VECTOR DATABASE CONFIGURATION (การตั้งค่าบริการ AI ส่วนตัว)
###############################################################################
# URL ปลายทางของบริการ Ollama (หากใช้ Docker network เดียวกัน สามารถใส่ http://ollama:11434 ได้)
OLLAMA_HOST=http://ollama:11434

# URL ปลายทางของ Qdrant Vector Database สำหรับการเก็บและค้นหาพิกัดเวกเตอร์
QDRANT_URL=http://qdrant:6333


###############################################################################
# REVERSE TUNNEL CONFIGURATION (การตั้งค่าช่องทางออนไลน์ออกอินเทอร์เน็ต)
###############################################################################

# --- วิธีที่ 1: NGROK SETTINGS (สำหรับผู้ที่ใช้ Ngrok Forward Port) ---
# โทเคนยืนยันตัวตน ได้จากหน้าเว็บ https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# โดเมนที่กดจองไว้ล่วงหน้าจากหน้าเว็บ Ngrok Cloud Edge Domains
NGROK_DOMAIN=your_reserved_domain.ngrok-free.app
# พอร์ตภายในเครื่องที่ติดตั้ง n8n ไว้ และต้องการให้ Ngrok ยิงเข้าหา (ปกติคือ 5678)
NGROK_PORT=5678

# --- วิธีที่ 2: CLOUDFLARE TUNNEL (สำหรับผู้ที่ใช้ Cloudflare Zero Trust) ---
# โทเคนสำเร็จรูปที่ได้จากการสร้าง Tunnel ในหน้า Cloudflare Zero Trust Dashboard
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here


###############################################################################
# EXTERNAL API KEYS & TOKENS (รหัสสำหรับเชื่อมต่อบริการภายนอกอื่น ๆ)
###############################################################################
# API Key สำหรับเรียกใช้งานโมเดล AI ประสิทธิภาพสูงและรวดเร็วจาก Groq Cloud Console
GROQ_API_KEY=gsk_your_groq_api_key_here

# Token สำหรับจัดการโครงสร้างพื้นฐานระบบ (Infrastructure Token)
infra_token=your_infrastructure_management_token

# Token สิทธิ์การเข้าถึงสำหรับบริการ LINE Messaging API เพื่อส่งข้อความแจ้งเตือนเข้าแอป LINE
line_token=your_line_channel_access_token

# Token ปลอดภัยสำหรับยืนยันสิทธิ์กับหน้าเว็บไซต์หลัก (Frontend Web Token Callback)
web_token=your_frontend_web_alert_token